# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-service-role-key      # backend uses service key; tenant isolation enforced in code
SUPABASE_JWT_SECRET=your-jwt-secret      # to verify Supabase-issued JWTs

# LLM (Gemini primary, Groq fallback)
LLM_PROVIDER=gemini                      # gemini | groq
GEMINI_API_KEY=your-gemini-key
GROQ_API_KEY=your-groq-key

# app
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
